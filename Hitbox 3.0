    panelOpen=not panelOpen
    if panelOpen then
        win.Visible=true win.Size=UDim2.new(0,0,0,48)
        TS:Create(win,TweenInfo.new(0.2,Enum.EasingStyle.Quint),{Size=UDim2.new(0,230,0,48)}):Play()
        TS:Create(triggerFrame,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(20,8,8)}):Play()
        TS:Create(trigIco,TweenInfo.new(0.15),{TextColor3=N.redHi}):Play()
    else
        if isExpanded then
            isExpanded=false expPanel.Visible=false
            win.Size=UDim2.new(0,230,0,48)
        end
        TS:Create(win,TweenInfo.new(0.15,Enum.EasingStyle.Quint),{Size=UDim2.new(0,0,0,48)}):Play()
        TS:Create(triggerFrame,TweenInfo.new(0.15),{BackgroundColor3=N.surf}):Play()
        TS:Create(trigIco,TweenInfo.new(0.15),{TextColor3=N.red}):Play()
        task.delay(0.15,function() if not panelOpen then win.Visible=false end end)
    end
end)

