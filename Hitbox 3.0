local N = {
    base   = Color3.fromRGB(6,6,9),
    surf   = Color3.fromRGB(13,13,18),
    card   = Color3.fromRGB(20,20,28),
    card2  = Color3.fromRGB(26,26,36),
    line   = Color3.fromRGB(36,36,50),
    red    = Color3.fromRGB(219,34,34),
    redHi  = Color3.fromRGB(255,60,60),
    green  = Color3.fromRGB(34,197,94),
    blue   = Color3.fromRGB(56,128,255),
    amber  = Color3.fromRGB(245,158,11),
    purple = Color3.fromRGB(139,92,246),
