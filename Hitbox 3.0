_uiStatus = function(reason)
    local map={
        lowhp="LOW HP",void="VOID",edge="EDGE",fling="FLING",
        sky="FLUNG",stuck="STUCK",death="DIED",manual="SAFE",
        oneshot="1-SHOT",monitoring="SAFE ✓",returned="↩ BACK"
    }
    local cols={
        lowhp=N.red,void=N.blue,edge=N.amber,fling=N.amber,
        sky=N.amber,stuck=N.amber,death=N.purple,manual=N.blue,
        oneshot=N.red,monitoring=N.green,returned=N.green
    }
    stLbl.Text=map[reason] or reason
    stLbl.TextColor3=cols[reason] or N.dim
end

local function buildPlayerList()
    for _,v in ipairs(plSc:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    local any=false
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=lp then any=true
            local b=Instance.new("TextButton")
            b.Size=UDim2.new(1,0,0,22) b.BackgroundColor3=Color3.fromRGB(13,13,19)
            b.TextColor3=N.dim b.Text="  👤 "..p.DisplayName
            b.Font=Enum.Font.GothamBold b.TextSize=9 b.BorderSizePixel=0
            b.TextXAlignment=Enum.TextXAlignment.Left b.Name=p.DisplayName b.ZIndex=14 b.Parent=plSc
            corner(b,5)
            b.MouseButton1Click:Connect(function()
                for _,x in ipairs(plSc:GetChildren()) do
                    if x:IsA("TextButton") then x.BackgroundColor3=Color3.fromRGB(13,13,19) x.TextColor3=N.dim end
                end
                if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    getgenv().lockedTarget=p.Character.HumanoidRootPart
                    b.BackgroundColor3=Color3.fromRGB(6,20,12) b.TextColor3=N.green
                    b.Text="  🔒 "..p.DisplayName
                    stLbl.Text="🔒 "..p.DisplayName stLbl.TextColor3=N.green
                end
            end)
        end
    end
    if not any then
        local l=Instance.new("TextLabel") l.Size=UDim2.new(1,0,0,22)
        l.BackgroundTransparency=1 l.Text="  No players" l.TextColor3=N.dim
        l.Font=Enum.Font.Gotham l.TextSize=9 l.ZIndex=14 l.Parent=plSc
    end
end

buildPlayerList()
Players.PlayerAdded:Connect(function() task.wait(0.5) buildPlayerList() end)
Players.PlayerRemoving:Connect(function(p)
    task.wait(0.1)
    if getgenv().lockedTarget and getgenv().lockedTarget.Parent
    and getgenv().lockedTarget.Parent.Name==p.Name then
        getgenv().lockedTarget=nil stLbl.Text="AUTO"
    end
    buildPlayerList()
end)

-- Live stats
local lastHealth2={}
RS.Heartbeat:Connect(function()
    if not human then return end
    local hpPct=(human.Health/human.MaxHealth)*100
    mDot.BackgroundColor3 = ST.isSafe and N.amber
        or ST.isInvis and N.purple
        or ST.active and N.green
        or hpPct<=CFG.lowHPPct and N.red
        or N.dim
    local p=math.floor(Ping:GetValue())
    pingV.Text=p.."ms"
    pingV.TextColor3=p<80 and N.green or p<150 and N.amber or N.red
    savesV.Text=(CFG.killZoneMax-ST.killSaves).." / "..CFG.killZoneMax
    savesV.TextColor3=ST.killSaves>=CFG.killZoneMax and N.red or N.amber
    safeStV.Text=ST.isSafe and "ACTIVE" or "Standby"
    safeStV.TextColor3=ST.isSafe and N.amber or N.dim
    hitsV.Text=tostring(ST.hitCount)
    dmgV.Text=math.floor(ST.totalDmg)
    skillV.Text=ST.skillActive and "YES" or "no"
    skillV.TextColor3=ST.skillActive and N.amber or N.dim
    if not ST.active then distV.Text="—" distV.TextColor3=N.dim return end
    local en=ST.cachedEnemy
    if en then
        local d=math.floor(en.d)
        distV.Text=d.." st"
        distV.TextColor3=d<10 and N.red or d<25 and N.amber or N.blue
        local dn=en.m.Name
        for _,pl in ipairs(Players:GetPlayers()) do if pl.Character==en.m then dn=pl.DisplayName break end end
        if not getgenv().lockedTarget then stLbl.Text=dn stLbl.TextColor3=N.green end
        for _,pl in ipairs(Players:GetPlayers()) do
            if pl~=lp and pl.Character then
                local h=pl.Character:FindFirstChildOfClass("Humanoid")
                if h then
                    local prev=lastHealth2[pl.Name] or h.Health
                    if h.Health<prev then ST.hitCount+=1 end
                    lastHealth2[pl.Name]=h.Health
                end
            end
        end
    else
        distV.Text="—" distV.TextColor3=N.dim
        if not getgenv().lockedTarget then stLbl.Text="SCAN" stLbl.TextColor3=N.dim end
    end
end)

-- ══════════════════════════════════════════════════════════════
-- RESPAWN
-- ══════════════════════════════════════════════════════════════
lp.CharacterAdded:Connect(function(c)
    char=c hrp=c:WaitForChild("HumanoidRootPart")
    human=c:WaitForChild("Humanoid")
    getgenv().ATCH=false getgenv().lockedTarget=nil
    ST.camLocked=false ST.hitCount=0 ST.totalDmg=0
    ST.hitCombo=0 ST.lastHitTime=0
    ST.lastHPVal=human.Health ST.damagedUntil=0
    ST.isSafe=false ST.safeCD=false ST.isInvis=false
    ST.flung=false ST.skillActive=false ST.skillUntil=0
    ST.originalSizes={} ST.lastEnemyHP={}
    ST.posHist={} ST.timeHist={}
    lastHealth2={}
    task.delay(0.5,function()
        local t=tick()
        repeat task.wait(0.1) until hrp.AssemblyLinearVelocity.Magnitude<2 or tick()-t>4
        buildPlatform()
    end)
    human.Died:Connect(function()
        if safeSettings.deathInvis then makeInvisible() end
        goSafe("death")
    end)
    camBtn.BackgroundColor3=Color3.fromRGB(16,16,24)
    camBtn.Text="📷" camStroke2.Color=N.line
    xF.Visible=false stLbl.Text="IDLE" stLbl.TextColor3=N.dim
    mDot.BackgroundColor3=N.dim
    buildPlayerList()
    if ST.active then task.wait(1.2) task.spawn(startHitbox) end
end)

print("◈ NEXUS loaded")
