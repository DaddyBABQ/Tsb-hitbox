    dim    = Color3.fromRGB(88,88,108),
    white  = Color3.fromRGB(255,255,255),
}

local function stroke(p,col,thick)
    local s=Instance.new("UIStroke") s.Color=col or N.line s.Thickness=thick or 1 s.Parent=p return s
end
local function corner(p,r) Instance.new("UICorner",p).CornerRadius=UDim.new(0,r or 10) end
local function grad(p,c0,c1,rot)
    local g=Instance.new("UIGradient")
    g.Color=ColorSequence.new{ColorSequenceKeypoint.new(0,c0),ColorSequenceKeypoint.new(1,c1)}
    g.Rotation=rot or 90 g.Parent=p return g
end

