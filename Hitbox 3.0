local function secLbl(txt)
    local f=Instance.new("TextLabel") f.Size=UDim2.new(1,0,0,14)
    f.BackgroundTransparency=1 f.Text=txt f.TextColor3=N.dim
    f.Font=Enum.Font.GothamBold f.TextSize=8
    f.TextXAlignment=Enum.TextXAlignment.Left f.ZIndex=13 f.Parent=esc
end

local function statRow(ico, lbl, col)
    local f=Instance.new("Frame") f.Size=UDim2.new(1,0,0,24)
    f.BackgroundColor3=N.card f.BorderSizePixel=0 f.ZIndex=13 f.Parent=esc
    corner(f,6)
    local i=Instance.new("TextLabel") i.Size=UDim2.new(0,18,1,0)
    i.BackgroundTransparency=1 i.Text=ico i.Font=Enum.Font.GothamBold
    i.TextSize=11 i.ZIndex=14 i.Parent=f
    local l=Instance.new("TextLabel") l.Size=UDim2.new(0.55,0,1,0) l.Position=UDim2.new(0,18,0,0)
    l.BackgroundTransparency=1 l.Text=lbl l.TextColor3=N.dim
    l.Font=Enum.Font.Gotham l.TextSize=9 l.TextXAlignment=Enum.TextXAlignment.Left
    l.ZIndex=14 l.Parent=f
    local v=Instance.new("TextLabel") v.Size=UDim2.new(0.4,-4,1,0) v.Position=UDim2.new(0.6,0,0,0)
    v.BackgroundTransparency=1 v.Text="—" v.TextColor3=col or N.txt
    v.Font=Enum.Font.GothamBold v.TextSize=9 v.TextXAlignment=Enum.TextXAlignment.Right
    v.ZIndex=14 v.Parent=f
    return v
end

local function mkToggle(lbl, getter, setter)
    local f=Instance.new("Frame") f.Size=UDim2.new(1,0,0,26)
    f.BackgroundColor3=N.card f.BorderSizePixel=0 f.ZIndex=13 f.Parent=esc
    corner(f,7)
    local t=Instance.new("TextLabel") t.Size=UDim2.new(0.72,0,1,0) t.Position=UDim2.new(0,8,0,0)
    t.BackgroundTransparency=1 t.Text=lbl t.TextColor3=N.dim
    t.Font=Enum.Font.Gotham t.TextSize=9 t.TextXAlignment=Enum.TextXAlignment.Left
    t.ZIndex=14 t.Parent=f
    local pill=Instance.new("Frame") pill.Size=UDim2.new(0,32,0,16) pill.Position=UDim2.new(1,-38,0.5,-8)
    pill.BorderSizePixel=0 pill.ZIndex=14 pill.Parent=f corner(pill,8)
    local knob=Instance.new("Frame") knob.Size=UDim2.new(0,11,0,11)
    knob.BorderSizePixel=0 knob.ZIndex=15 knob.Parent=pill corner(knob,6)
    local function set(v)
        setter(v)
        TS:Create(pill,TweenInfo.new(0.12),{BackgroundColor3=v and N.green or N.line}):Play()
        TS:Create(knob,TweenInfo.new(0.12),{
            Position=v and UDim2.new(0,18,0.5,-5) or UDim2.new(0,3,0.5,-5),
            BackgroundColor3=v and N.white or N.dim
        }):Play()
    end
    set(getter())
    local btn=Instance.new("TextButton") btn.Size=UDim2.new(1,0,1,0)
    btn.BackgroundTransparency=1 btn.Text="" btn.ZIndex=16 btn.Parent=f
    btn.MouseButton1Click:Connect(function() set(not getter()) end)
end

local function mkAction(lbl, col, fn)
    local b=Instance.new("TextButton") b.Size=UDim2.new(1,0,0,24)
    b.BackgroundColor3=Color3.fromRGB(14,14,20) b.TextColor3=col
    b.Text=lbl b.Font=Enum.Font.GothamBold b.TextSize=9
    b.BorderSizePixel=0 b.ZIndex=13 b.Parent=esc
    corner(b,6) stroke(b,col,0.8)
    b.MouseButton1Click:Connect(fn) return b
end

