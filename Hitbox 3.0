plSc.BackgroundColor3=Color3.fromRGB(9,9,14) plSc.BorderSizePixel=0
plSc.ScrollBarThickness=2 plSc.ScrollBarImageColor3=N.line
plSc.CanvasSize=UDim2.new(0,0,0,0) plSc.AutomaticCanvasSize=Enum.AutomaticSize.Y
