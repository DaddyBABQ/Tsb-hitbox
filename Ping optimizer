-- Build baseline
task.spawn(function()
    task.wait(2)
    for i=1,25 do
        table.insert(pingHist, math.floor(Ping:GetValue()))
        task.wait(0.4)
    end
    local sum = 0
    for _, v in ipairs(pingHist) do sum += v end
    stabBaseline = math.floor(sum / #pingHist)
    pingEMA = stabBaseline
    stabLbl.Text = "STABILIZER · ARMED @" .. stabBaseline .. "ms"
    stabLbl.TextColor3 = Color3.fromRGB(34,197,94)
end)

-- Main loop (graph + ping display fixed)
RS.Heartbeat:Connect(function()
    local raw = math.floor(Ping:GetValue())
    pingEMA = math.floor(EMA_ALPHA * raw + (1 - EMA_ALPHA) * pingEMA)

    pVal.Text = pingEMA .. " ms"
    local col = pingEMA < 60 and Color3.fromRGB(34,197,94) or pingEMA < 100 and Color3.fromRGB(245,158,11) or Color3.fromRGB(219,34,34)
    pDot.BackgroundColor3 = col
    pVal.TextColor3 = col

    local spike = raw - (stabBaseline + SPIKE_THRESHOLD)
    if spike > 0 then
        stabSpikes += 1
        stabLbl.Text = "⚡ +" .. spike .. "ms"
        stabLbl.TextColor3 = Color3.fromRGB(219,34,34)
        if (tick() - lastReapply) > REAPPLY_COOLDOWN then
            lastReapply = tick()
            applyFlags()
        end
    else
        local jitter = math.abs(raw - pingEMA)
        if jitter < 8 then
            stabLbl.Text = "✓ " .. pingEMA .. "ms"
            stabLbl.TextColor3 = Color3.fromRGB(34,197,94)
        else
            stabLbl.Text = "\~ " .. jitter .. "ms jitter"
            stabLbl.TextColor3 = Color3.fromRGB(245,158,11)
        end
    end

    -- Graph (fixed + throttled)
    if math.random(1,3) == 1 then
        local maxP = 1
        for _, v in ipairs(pingHist) do if v > maxP then maxP = v end end
        for i = 1, math.min(#pingHist, BAR_COUNT) do
            local h = math.clamp(pingHist[i] / maxP, 0.05, 1)
            graphBars[i].Size = UDim2.new(1/BAR_COUNT, -0.5, h, 0)
            local c = pingHist[i] < 60 and Color3.fromRGB(34,197,94) or pingHist[i] < 100 and Color3.fromRGB(245,158,11) or Color3.fromRGB(219,34,34)
            graphBars[i].BackgroundColor3 = c
        end
    end
end)

