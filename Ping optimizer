    TS:Create(prog,TweenInfo.new(dur,Enum.EasingStyle.Linear),{Size=UDim2.new(0,0,0,2)}):Play()
    task.delay(dur,function()
        TS:Create(card,TweenInfo.new(0.28,Enum.EasingStyle.Quint),{Position=UDim2.new(1,20,0,0),BackgroundTransparency=1}):Play()
        TS:Create(cs,TweenInfo.new(0.28),{Transparency=1}):Play()
        task.delay(0.28,function() card:Destroy() end)
    end)
end

