local pingHist = {}
local pingEMA = 0
local stabBaseline = 0
local stabSpikes = 0
local lastReapply = 0
local EMA_ALPHA = 0.15
local SPIKE_THRESHOLD = 30
local REAPPLY_COOLDOWN = 2.5

local function applyFlags()
    local flags = {
        ["DFIntNetworkPrediction"] = "240",
        ["DFIntInterpolationAwareTargetTimeLerpHundredth"] = "195",
        ["FFlagEnableReducedLatency"] = "True",
