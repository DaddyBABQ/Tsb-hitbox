local function conn(c) table.insert(S.conns,c) end
local function addGC(n) S.gcBucket=S.gcBucket+n end
local function getMem() return floor(GC("count")/1024*10)/10 end
local function isMob() return UIS.TouchEnabled and not UIS.KeyboardEnabled end
local function EWMA(o,n,a) return a*n+(1-a)*o end

-- Ping stat cached
local pingStat; pcall(function()
    pingStat=Stats.Network.ServerStatsItem["Data Ping"]
end)
local function getPing()
    if pingStat then local ok,v=pcall(function() return floor(pingStat:GetValue()) end)
        if ok then return v end end return S.smPing
end

-- Classes for fast lookup
local PARTICLES={ParticleEmitter=true,Fire=true,Smoke=true,Sparkles=true}
local SHADOWS={BasePart=true,UnionOperation=true,MeshPart=true,Part=true,WedgePart=true}
local LIGHTS={PointLight=true,SpotLight=true,SurfaceLight=true}
local POSTFX={BloomEffect=true,DepthOfFieldEffect=true,SunRaysEffect=true,
              ColorCorrectionEffect=true,BlurEffect=true}

-- FPS cap
