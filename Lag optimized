        end
        TS:Create(ringStroke,TW2,{Transparency=0.15}):Play()
        taskw(0.9)
    end
end)

-- GUI update
local LVL={"OFF","LOW","MED","HIGH","MAX"}
local function cP(v) return v<80 and cGrn or v<150 and cYel or cAcc end
local function cF(v) return v>=55 and cGrn or v>=30 and cYel or cAcc end
local function cM(v) return v<300 and cGrn or v<400 and cYel or cAcc end
local function cS(v) return v==0 and cGrn or v<5 and cYel or cAcc end

conn(RS.RenderStepped:Connect(function()
    local now=tickf()
    if (now-S.lastGui)<(1/C.GuiHz) then return end
    S.lastGui=now
    local up=floor(now-S.startTime); local mem=getMem()

    vals["PING"].Text=S.rawPing.."ms";  vals["PING"].TextColor3=cP(S.rawPing)
    vals["SMOOTH"].Text=S.smPing.."ms"; vals["SMOOTH"].TextColor3=cP(S.smPing)
    vals["FPS"].Text=S.fps.."fps";      vals["FPS"].TextColor3=cF(S.fps)
    vals["MEM"].Text=mem.."MB";         vals["MEM"].TextColor3=cM(mem)
    vals["P.SPK"].Text=tostring(S.pSpikes); vals["P.SPK"].TextColor3=cS(S.pSpikes)
    vals["L.SPK"].Text=tostring(S.lSpikes); vals["L.SPK"].TextColor3=cS(S.lSpikes)
    vals["REC"].Text=LVL[S.spikeLevel+1] or "OFF"
    vals["REC"].TextColor3=S.spikeLevel==0 and cGrn or cYel
    vals["UP"].Text=fmt("%dm%02ds",floor(up/60),up%60)
    vals["UP"].TextColor3=cDim
end))

