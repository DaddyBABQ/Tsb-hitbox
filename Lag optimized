local R_CLOSE=UDim2.new(0,-3,     0.5,-(CD/2+3))
local R_OPEN =UDim2.new(0,PW+CD+3,0.5,-(CD/2+3))

local function setOpen(state)
    if busy then return end; busy=true; isOpen=state
    Arrow.Text=state and "◀" or "▶"
    TS:Create(Panel,TW,{Position=state and P_OPEN or P_CLOSE}):Play()
    TS:Create(Btn,  TW,{Position=state and B_OPEN or B_CLOSE}):Play()
    TS:Create(Ring, TW,{Position=state and R_OPEN or R_CLOSE}):Play()
    taskdl(0.26,function() busy=false end)
end

Btn.MouseButton1Click:Connect(function() setOpen(not isOpen) end)
