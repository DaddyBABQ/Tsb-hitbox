Lighting.ClockTime=14; Lighting.GeographicLatitude=0

local function killFX(v)
    if not v or not v.Parent then return end
    if POSTFX[v.ClassName] then pcall(function() v.Enabled=false end) end
    if v.ClassName=="Atmosphere" then pcall(function()
        v.Density=0; v.Glare=0; v.Haze=0; v.Offset=0
    end) end
end
for _,v in ipairs(Lighting:GetChildren()) do killFX(v) end
conn(Lighting.ChildAdded:Connect(function(v) taskd(function() killFX(v) end) end))

-- Terrain
pcall(function()
    local t=WS:FindFirstChildOfClass("Terrain")
    if t then t.WaterWaveSize=0;t.WaterWaveSpeed=0;t.WaterReflectance=0
             t.WaterTransparency=1;t.Decoration=false end
end)

-- Part sanitizer (single pass, class-lookup)
local charSet={}
local function rebuildChars()
    charSet={}
    for _,p in ipairs(Players:GetPlayers()) do
        if p.Character then charSet[p.Character]=true end
    end
end
local function inChar(v)
    local a=v
    for _=1,8 do a=a.Parent; if not a then return false end
        if charSet[a] then return true end end return false
end

local function sanitize(v)
    local cn=v.ClassName
    pcall(function()
        if SHADOWS[cn]  then v.CastShadow=false end
        if PARTICLES[cn] then
            if cn=="ParticleEmitter" then v.Rate=0 end; v.Enabled=false
        end
        if cn=="Decal" or cn=="Texture" then v.Transparency=1 end
        if cn=="SurfaceAppearance" then v:Destroy(); return end
        if cn=="Beam" or cn=="Trail" then v.Enabled=false end
        if LIGHTS[cn] and not inChar(v) then v.Enabled=false end
    end)
end

local function batchScan(model)
    if not model then return end
    local list=model:GetDescendants(); local i=0; local n=#list
    local function step()
        for _=1,80 do i+=1; if i>n then return end; sanitize(list[i]) end
        if i<n then taskd(step) end
    end; taskd(step)
end

local function onChar(char)
    if not char then return end
    taskdl(0.1,rebuildChars); taskdl(0.6,function() batchScan(char) end)
end

-- Watch players
rebuildChars()
for _,p in ipairs(Players:GetPlayers()) do
    if p.Character then onChar(p.Character) end
    conn(p.CharacterAdded:Connect(onChar))
end
conn(Players.PlayerAdded:Connect(function(p)
    conn(p.CharacterAdded:Connect(onChar))
    if p.Character then onChar(p.Character) end
end))
conn(Players.PlayerRemoving:Connect(function() taskdl(0.1,rebuildChars) end))
onChar(LP.Character or LP.CharacterAdded:Wait())
conn(LP.CharacterAdded:Connect(onChar))

-- Live effect watcher
conn(WS.DescendantAdded:Connect(function(v)
    if S.active then taskd(function() if v and v.Parent then sanitize(v) end end) end
end))

-- Initial workspace scan
taskd(function() batchScan(WS) end)

-- GC manager (frame-budgeted)
conn(RS.Heartbeat:Connect(function()
    if S.gcBucket<=0 then return end
    local w=min(S.gcBucket,C.GCBudget)
    GC("step",w); S.gcBucket=max(0,S.gcBucket-w)
end))

-- Ping system
conn(RS.Heartbeat:Connect(function()
    if not S.active then return end
    local now=tickf(); local raw=getPing()
    S.rawPing=raw
    S.smPing=floor(EWMA(S.smPing,raw,raw>S.smPing and C.EWMA_UP or C.EWMA_DN))
    if raw>C.PingSpike then
        S.pSpikes+=1
        if (now-S.lastSpike)<2.5 then S.spikeLevel=min(S.spikeLevel+1,4) end
        S.lastSpike=now
        addGC(C.SpikeGC[max(1,S.spikeLevel)] or 80)
    elseif (now-S.lastSpike)>C.SpikeReset and S.spikeLevel>0 then
        S.spikeLevel-=1
    end
    if (now-S.lastNet)>=C.NetClean then S.lastNet=now; addGC(180) end
end))

-- Lag spike killer
conn(RS.Heartbeat:Connect(function(dt)
    if not S.active then return end
    local now=tickf()
    S.fps=clamp(floor(1/max(dt,0.001)),1,999)
    if dt>C.LagCrit then
        S.lSpikes+=1; addGC(700)
        taskd(function()
            for _,v in ipairs(WS:GetDescendants()) do
                if PARTICLES[v.ClassName] then
                    pcall(function() if v.ClassName=="ParticleEmitter" then v.Rate=0 end
                        v.Enabled=false end)
                end
            end
        end)
    elseif dt>C.LagWarn then
        S.lSpikes+=1; addGC(280)
    end
    if (now-S.lastMem)>=C.MemClean then
        S.lastMem=now
        if getMem()>C.MemCrit then
            tasksp(function()
                GC("collect"); taskw(); GC("collect"); taskw()
                for _=1,3 do GC("step",300); taskw() end
            end)
        else addGC(300) end
    end
end))

