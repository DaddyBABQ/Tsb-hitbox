-- Toggle logic
local isOpen,busy=false,false
local P_CLOSE=UDim2.new(0,-(PW+4),0.5,-PH/2)
local P_OPEN =UDim2.new(0,CD+5,   0.5,-PH/2)
local B_CLOSE=UDim2.new(0,0,      0.5,-CD/2)
